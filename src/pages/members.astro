---
import Layout from "@/layouts/Layout.astro";
import { membersByYear } from "@/data/members";
import { sortMembersByRole, separateMembersByDisplayType, isPresidentRole, isFoundingPresident } from "@/utils/memberUtils";
import { DISCORD_LINK, GOOGLE_FORM_URL } from "@/consts";

const sortedMembers = sortMembersByRole(membersByYear);
const yearKeys = Object.keys(sortedMembers);
---

<Layout title="Members - progsu">
  <div class="min-h-screen bg-black">

    <!-- Hero -->
    <section class="pt-32 pb-16 px-8">
      <div class="max-w-4xl mx-auto text-center float-in">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight italic" style="font-family: 'Noto Serif', Georgia, serif !important;">
          the people
        </h1>
        <p class="text-base md:text-lg text-white/50 leading-relaxed font-light max-w-2xl mx-auto" style="font-family: 'Helvetica Neue', sans-serif;">
          every era of progsu, shaped by the people who showed up and built something.
        </p>
      </div>
    </section>

    <!-- Year Navigation -->
    <section class="px-8 pb-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex justify-center gap-6 flex-wrap">
          {yearKeys.map((year, i) => (
            <button
              data-year={year}
              class:list={[
                "year-tab text-sm tracking-widest transition-all duration-300 pb-1",
                i === 0
                  ? "text-white border-b border-white/40"
                  : "text-white/30 hover:text-white/60 border-b border-transparent",
              ]}
              style="font-family: 'Helvetica Neue', sans-serif;"
            >
              {year}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Members by Year -->
    {yearKeys.map((year, yearIndex) => {
      const members = sortedMembers[year];
      const { fullCardMembers, liteCardMembers, listMembers } = separateMembersByDisplayType(members);
      const allDisplayMembers = [...fullCardMembers, ...liteCardMembers];

      return (
        <section
          data-year-content={year}
          class:list={["year-content px-8 pb-24", yearIndex === 0 ? "" : "hidden"]}
        >
          <div class="max-w-5xl mx-auto float-in">

            {/* Leadership + Core */}
            {allDisplayMembers.length > 0 && (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-16 mb-20">
                {allDisplayMembers.map((member) => {
                  const isPresident = isPresidentRole(member.role);
                  const isFounding = isFoundingPresident(member.role);
                  return (
                    <div class="text-center space-y-3">
                      {/* Initials circle */}
                      <div class:list={[
                        "w-16 h-16 rounded-full mx-auto flex items-center justify-center text-lg font-bold",
                        isFounding
                          ? "bg-purple-500/20 text-purple-300"
                          : isPresident
                            ? "bg-amber-500/20 text-amber-300"
                            : "bg-white/5 text-white/60",
                      ]}>
                        {member.name.split(" ").map((n: string) => n[0]).join("")}
                      </div>

                      <div>
                        <h3 class="text-white font-medium text-base italic" style="font-family: 'Noto Serif', Georgia, serif !important;">
                          {member.name}
                        </h3>
                        <p class:list={[
                          "text-xs tracking-widest mt-1",
                          isFounding
                            ? "text-purple-400/70"
                            : isPresident
                              ? "text-amber-400/70"
                              : "text-white/30",
                        ]} style="font-family: 'Helvetica Neue', sans-serif;">
                          {member.role.toLowerCase()}{member.team ? ` · ${member.team.toLowerCase()}` : ""}
                        </p>
                      </div>

                      {member.specialties && member.specialties.length > 0 && (
                        <div class="flex flex-wrap justify-center gap-2">
                          {member.specialties.slice(0, 3).map((s: string) => (
                            <span class="text-white/20 text-xs" style="font-family: 'Helvetica Neue', sans-serif;">
                              {s.toLowerCase()}
                            </span>
                          ))}
                        </div>
                      )}

                      {/* Social links */}
                      <div class="flex justify-center gap-4 pt-1">
                        {member.github && (
                          <a
                            href={`https://github.com/${member.github}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-white/20 hover:text-white/60 text-xs tracking-widest transition-all duration-300"
                            style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
                            onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
                            onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
                          >
                            github
                          </a>
                        )}
                        {member.linkedin && (
                          <a
                            href={member.linkedin.startsWith("http") ? member.linkedin : `https://linkedin.com/in/${member.linkedin}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-white/20 hover:text-white/60 text-xs tracking-widest transition-all duration-300"
                            style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
                            onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
                            onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
                          >
                            linkedin
                          </a>
                        )}
                      </div>
                    </div>
                  );
                })}
              </div>
            )}

            {/* General Members */}
            {listMembers.length > 0 && (
              <div>
                <p class="text-white/20 text-xs tracking-[0.3em] uppercase text-center mb-8" style="font-family: 'Helvetica Neue', sans-serif;">
                  members
                </p>
                <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 max-w-3xl mx-auto">
                  {listMembers.map((member) => (
                    <span class="text-white/25 text-sm" style="font-family: 'Helvetica Neue', sans-serif;">
                      {member.name.toLowerCase()}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>
      );
    })}

    <!-- Join CTA -->
    <section class="py-16 px-8">
      <div class="max-w-2xl mx-auto text-center float-in">
        <p class="text-white/40 text-sm tracking-widest mb-6" style="font-family: 'Helvetica Neue', sans-serif;">
          want to be on this page?
        </p>
        <div class="flex justify-center gap-8">
          <a
            href={GOOGLE_FORM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/40 hover:text-white text-sm tracking-widest transition-all duration-300"
            style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
            onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
            onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
          >
            join progsu
          </a>
          <a
            href={DISCORD_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/40 hover:text-white text-sm tracking-widest transition-all duration-300"
            style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
            onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
            onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
          >
            discord
          </a>
        </div>
      </div>
    </section>

    <!-- Back + Footer -->
    <div class="py-8 text-center">
      <a
        href="/"
        class="text-white/30 hover:text-white text-sm tracking-widest transition-all duration-300"
        style="font-family: 'Helvetica Neue', sans-serif; text-shadow: 0 0 8px rgba(147, 51, 234, 0);"
        onmouseover="this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)'"
        onmouseout="this.style.textShadow='0 0 8px rgba(147,51,234,0)'"
      >
        &larr; back to home
      </a>
      <p class="text-white/20 text-xs mt-6 tracking-widest" style="font-family: 'Helvetica Neue', sans-serif;">
        &copy; 2025 progsu
      </p>
    </div>
  </div>
</Layout>

<style>
  .float-in {
    opacity: 0;
    transform: translateY(40px);
    filter: blur(10px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out, filter 0.9s ease-out;
  }

  .float-in.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
</style>

<script>
  function initMembers() {
    // Float-in animation
    const floatEls = document.querySelectorAll('.float-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    floatEls.forEach((el) => observer.observe(el));

    // Year tab switching
    const tabs = document.querySelectorAll('.year-tab');
    const contents = document.querySelectorAll('.year-content');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const year = (tab as HTMLElement).dataset.year;

        // Update tab styles
        tabs.forEach((t) => {
          t.classList.remove('text-white', 'border-white/40');
          t.classList.add('text-white/30', 'border-transparent');
        });
        tab.classList.remove('text-white/30', 'border-transparent');
        tab.classList.add('text-white', 'border-white/40');

        // Show/hide content
        contents.forEach((c) => {
          const el = c as HTMLElement;
          if (el.dataset.yearContent === year) {
            el.classList.remove('hidden');
            // Re-trigger float-in
            const floatIn = el.querySelector('.float-in');
            if (floatIn) {
              floatIn.classList.remove('visible');
              requestAnimationFrame(() => {
                floatIn.classList.add('visible');
              });
            }
          } else {
            el.classList.add('hidden');
          }
        });
      });
    });

    // Purple glow on year tabs hover
    tabs.forEach((tab) => {
      const el = tab as HTMLElement;
      el.addEventListener('mouseover', () => {
        el.style.textShadow = '0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';
      });
      el.addEventListener('mouseout', () => {
        el.style.textShadow = '0 0 8px rgba(147,51,234,0)';
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMembers);
  } else {
    initMembers();
  }
  document.addEventListener('astro:page-load', initMembers);
</script>
