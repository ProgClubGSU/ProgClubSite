---
import { QUOTE, SITE_TITLE } from "@/consts";
import HeroGallery from "@/components/HeroGallery";
---

<section
  class="min-h-screen !z-[20] relative w-full flex items-center justify-center overflow-hidden"
  id="hero"
>
  <!-- 3D Gallery Background -->
  <div class="absolute inset-0 z-0">
    <HeroGallery client:load />
  </div>

  <!-- Overlay content with mix-blend-exclusion -->
  <div class="absolute inset-0 pointer-events-none flex items-center justify-center z-10 mix-blend-exclusion text-white">
    <div class="text-center px-4">
      <h1 class="font-bold text-5xl md:text-7xl lg:text-8xl tracking-tight" style="font-family: 'Helvetica Neue', sans-serif;">
        progsu
      </h1>
    </div>
  </div>

</section>
