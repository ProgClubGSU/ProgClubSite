---
interface Props {
  title?: string;
  variant?: 'default' | 'gradient' | 'bordered';
  class?: string;
}

const { title, variant = 'default', class: className = '' } = Astro.props;

const variants = {
  default: 'bg-white/[0.02] border border-white/5',
  gradient: 'bg-white/[0.02] border border-white/5',
  bordered: 'bg-white/[0.02] border border-white/10',
};
---

<div class={`rounded-lg p-6 my-4 ${variants[variant]} ${className}`}>
  {title && (
    <h3 class="text-base font-semibold text-white mb-3" style="font-family: 'Noto Serif', Georgia, serif; font-style: italic;">{title}</h3>
  )}
  <div class="text-white/40 text-sm [&>*:first-child]:mt-0">
    <slot />
  </div>
</div>
